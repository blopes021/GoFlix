# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TMDB_API_KEY: Required for fetching movie data from The Movie Database.
# Get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Configuration for Admin Notifications
# Used to notify the admin when content is reported as unavailable.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ADMIN_EMAIL="fabricio.lopes.a@gmail.com"

# Monetag Configuration
# VITE_MONETAG_DIRECT_LINK: The direct link URL from your Monetag dashboard.
# VITE_MONETAG_TAG_ID: The Zone ID/Tag ID for the Smart Tag script.
VITE_MONETAG_DIRECT_LINK="https://omg10.com/4/10855614"
VITE_MONETAG_TAG_ID="10855614"
